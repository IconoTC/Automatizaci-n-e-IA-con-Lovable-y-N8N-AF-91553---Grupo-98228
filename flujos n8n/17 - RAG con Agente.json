    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "63e9ebce-86e0-48e3-bb02-d399ebdfbea2",
              "name": "text",
              "value": "=You are an assistant that answers questions using your knowledge. \n\nQuestion:\n{{ $json.question }}\n\nAnswer:",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1536,
