    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a retrieval planning agent.\n\nYour task is to analyze the user's question and decide\nhow the system should retrieve information.\n\nYou must return ONLY a valid JSON object with the following fields:\n- retrieval_strategy: \"keyword\" or \"none\"\n- top_k: number\n- reason: short explanation\n\nRules:\n- If the question can be answered from general knowledge,\n  use retrieval_strategy = \"none\".\n- If the question refers to specific documents or regions,\n  use retrieval_strategy = \"keyword\".\n- Keep the JSON concise.\n- Do not include any extra text outside the JSON.\n\nUser question:\n{{ $json.question }}\n",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
