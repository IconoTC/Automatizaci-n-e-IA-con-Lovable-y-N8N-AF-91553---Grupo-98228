      ],
      "id": "1c354b6f-c631-4ae1-b89b-c935f0884f1b",
      "name": "Construir Prompt Final - versión SIMPLE"
    },
    {
      "parameters": {
        "jsCode": "// Tomamos la pregunta\nconst question = $json.question.toLowerCase();\n \n// Generamos palabras clave (filtro simple)\nconst keywords = question.split(/\\W+/).filter(k => k.length > 3);\n \n// Tomamos los textos\nconst texts = $json.texts;\n \n// Score simple: contar coincidencias de palabras clave\nconst scoredDocs = texts.map(text => {\n  const t = text.toLowerCase();\n  let score = 0;\n  for (const kw of keywords) {\n    if (t.includes(kw)) score++;\n  }\n  return { text, score };\n});\n \n// Orden descendente por score\nscoredDocs.sort((a, b) => b.score - a.score);\n \n// Seleccionamos top 3 documentos\nconst topDocs = scoredDocs.slice(0, 3).map(d => d.text);\n \n// Salida: 1 item con topDocs + pregunta\nreturn [{\n  json: {\n    texts: topDocs, // array con los 3 textos relevantes\n    question\n  }\n}];"
      },
