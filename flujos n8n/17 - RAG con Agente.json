      "name": "Merge1"
    },
    {
      "parameters": {
        "jsCode": "// Extraer el string\nconst raw = $json.output;\n\n// Eliminar los ```json ``` si existen\nconst cleaned = raw\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\n// Parsear a objeto\nconst agentDecision = JSON.parse(cleaned);\n\n// Devolver como JSON limpio\nreturn [{\n  json: agentDecision\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        992,
        -128
      ],
